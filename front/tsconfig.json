{
  "compilerOptions": {
    "target": "es2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@Pages/*": [
        "./src/pages/*"
      ],
      "@Store/*": [
        "./src/store/*"
      ],
      "@Hooks/*": [
        "./src/hooks/*"
      ],
      "@Api/*": [
        "./src/api/*"
      ],
      "@Components/*": [
        "./src/components/*"
      ],
      "@Types/*": [
        "./src/types/*"
      ],
    }
  },
  "include": [
    "src"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
