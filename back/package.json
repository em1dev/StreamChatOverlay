{
  "name": "chat.back",
  "version": "1.0.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "nodemon ./src/index.ts | pino-pretty --singleLine -o \"{req.method} {req.url} {res.statusCode} {msg}\"",
    "lint": "eslint . --ext ts && tsc --noEmit",
    "build": "tsc",
    "start": "node ./dist | pino-pretty --singleLine -o \"{req.method} {req.url} {res.statusCode} {msg}\"",
    "migrate": "node ./dist/repository/migrations",
    "build-proto": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:./src/proto  --grpc_out=./src/proto  -I ./src/proto  ./src/proto/*.proto",
    "build-proto-2": "grpc_tools_node_protoc   --ts_out=./src/proto  -I ./src/proto  ./src/proto/*.proto"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@vscode/sqlite3": "5.1.12-vscode",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-ws": "^5.0.2",
    "globals": "^17.6.0",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "redis": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-ws": "^3.0.6",
    "@types/google-protobuf": "^3.15.12",
    "eslint": "^10.4.1",
    "grpc-tools": "^1.13.1",
    "grpc_tools_node_protoc_ts": "^5.3.3",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
